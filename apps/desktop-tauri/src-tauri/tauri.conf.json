{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cursor Usage Extension",
  "version": "1.1.0",
  "identifier": "com.taeinn.cursor-usage-extension",
  "build": {
    "beforeDevCommand": "pnpm dev:web --host 127.0.0.1 --port 1420 --strictPort",
    "beforeBuildCommand": "pnpm exec vite build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Cursor Usage Extension",
        "width": 430,
        "height": 600,
        "minWidth": 430,
        "minHeight": 224,
        "maxWidth": 430,
        "maxHeight": 600,
        "resizable": false,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "backgroundColor": "#00000000",
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png"
    ]
  }
}
